FROM qwen3:14b

# 14.8B Q4 (~9GB) exceeds 8GB VRAM, so it runs CPU-split (slower) — accepted for the
# quality bump. num_ctx must be baked (Ollama defaults to 4096); 32768 leaves headroom.
PARAMETER num_ctx      32768
PARAMETER num_predict  8192

# Qwen3 thinking-mode recommended sampling.
PARAMETER temperature   0.6
PARAMETER top_p         0.95
PARAMETER top_k         20
PARAMETER repeat_penalty 1.05
