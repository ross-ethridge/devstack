FROM qwen2.5-coder:7b

# 8B fits 100% on the 8GB GPU. num_ctx must be baked (Ollama defaults to 4096); 40960 is
# qwen3:8b's native window. Tool calls parse correctly on Ollama (unlike qwen2.5-coder).
PARAMETER num_ctx      32768
PARAMETER num_predict  8192

# Qwen3 thinking-mode recommended sampling (don't use greedy/temp 0 with thinking).
PARAMETER temperature   0.6
PARAMETER top_p         0.95
PARAMETER top_k         20
PARAMETER repeat_penalty 1.05
